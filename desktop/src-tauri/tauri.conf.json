{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Claude Code",
  "version": "0.1.0",
  "identifier": "com.opencode.code",
  "build": {
    "beforeBuildCommand": "powershell -NoProfile -Command \"Set-Location (Resolve-Path ..\\frontend); bun run build\"",
    "beforeDevCommand": "powershell -NoProfile -Command \"Set-Location (Resolve-Path ..\\frontend); bun run dev\"",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Open Claude Code",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
